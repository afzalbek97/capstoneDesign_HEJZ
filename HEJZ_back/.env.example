# =============================================
# U-STAR Backend — Environment Variables
# =============================================
# Bu faylni nusxalab .env nomini bering:
#   cp .env.example .env
# Keyin qiymatlarni to'ldiring.
# docker-compose.yml shu fayldan o'qiydi.

# ----- MySQL -----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=capstone_db
MYSQL_USER=hejz_user
MYSQL_PASSWORD=hejz_password

# ----- OpenAI -----
OPENAI_API_KEY=sk-...
OPENAI_API_MODEL=gpt-4o-mini

# ----- SUNO -----
SUNO_API_KEY=your_suno_api_key_here

# ----- AWS S3 -----
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_KEY=your_aws_secret_key
CLOUD_AWS_S3_BUCKET=your_bucket_name
CLOUD_AWS_REGION_STATIC=ap-northeast-2

# ----- JWT -----
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
JWT_EXPIRES_MS=86400000
