# =============================================
# U-STAR Frontend — Environment Variables
# =============================================
# Bu faylni nusxalab .env nomini bering:
#   cp .env.example .env
# Keyin qiymatlarni to'ldiring.

# SUNO API kaliti (App.tsx da ApiContext orqali ishlatiladi)
API_SUNO_KEY=your_suno_api_key_here

# Backend API URL (App.tsx da ApiContext orqali ishlatiladi)
# Odatda baseUrl.ts dan avtomatik aniqlanadi, lekin bu ham kerak
API_URL=http://10.0.2.2:8080
